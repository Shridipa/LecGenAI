{
  "name": "lecgen-aicte-root",
  "version": "1.0.0",
  "description": "Root management for LecGen AICTE project",
  "scripts": {
    "install:all": "npm install --prefix frontend && pip install -r requirements.txt",
    "backend": "venv\\Scripts\\python.exe -m uvicorn api.main:app --reload --port 8000",
    "backend:stable": "venv\\Scripts\\python.exe -m uvicorn api.main:app --port 8000",
    "frontend": "npm run dev --prefix frontend",
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "clean": "powershell -Command \"Remove-Item -Path uploads\\* -Recurse -Force; Remove-Item -Path outputs\\* -Recurse -Force\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "localtunnel": "^2.0.2"
  }
}
